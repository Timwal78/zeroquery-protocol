{
  "name": "@zeroquery/sdk",
  "version": "0.1.0",
  "description": "Proof-of-Intent (PoI) protocol SDK — DID resolution, intent gossip, escrow rails. No custody, no token.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
